{
  "expo": {
    "name": "SmartWaste AI",
    "slug": "smartwaste-ai",
    "version": "2.3.8",
    "sdkVersion": "54.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "package": "com.smartwaste.ai",
      "versionCode": 12,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#16a34a"
      },
      "config": {
        "googleMaps": {
          "apiKey": "$EXPO_PUBLIC_GOOGLE_API_KEY"
        }
      },
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "SmartWaste needs location to optimize collection routes."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "SmartWaste needs camera to photograph waste bins."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "SmartWaste needs photo access to attach images to waste reports.",
          "cameraPermission": "SmartWaste needs camera to capture waste bin photos."
        }
      ],
      "expo-notifications"
    ],
    "extra": {
      "apiUrl": "https://smartwaste-ai-f0i9.onrender.com",
      "eas": {
        "projectId": "41ccdf6f-e09b-4cda-8540-a1afb4425748"
      }
    },
    "owner": "himanshu2992004"
  }
}
