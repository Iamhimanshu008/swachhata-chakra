{
  "expo": {
    "name": "SmartWaste AI",
    "slug": "smartwaste-ai",
    "version": "2.0.0",
    "sdkVersion": "54.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "package": "com.smartwaste.ai",
      "versionCode": 2,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#16a34a"
      },
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "SmartWaste needs location to optimize collection routes."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "SmartWaste needs camera to photograph waste bins."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#2D6A4F"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "41ccdf6f-e09b-4cda-8540-a1afb4425748"
      }
    },
    "owner": "himanshu2992004"
  }
}
